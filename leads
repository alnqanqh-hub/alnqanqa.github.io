<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>TEAM CLEAN</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
  margin:0;
  font-family:Arial;
  background:#0b0b0b;
  color:#fff;
}

.hero {
  height:100vh;
  background:url('https://images.unsplash.com/photo-1581578731548-c64695cc6952') center/cover;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
}

.hero h1 {
  font-size:50px;
  color:gold;
}

.section {
  padding:40px 20px;
  text-align:center;
}

input, select {
  width:90%;
  padding:12px;
  margin:10px 0;
  border-radius:10px;
  border:none;
}

button {
  background:gold;
  color:black;
  padding:12px 20px;
  border:none;
  border-radius:10px;
  font-weight:bold;
  cursor:pointer;
}
</style>
</head>

<body>

<div class="hero">
  <div>
    <h1>TEAM CLEAN</h1>
    <p>أفضل شركة تنظيف في السعودية</p>
  </div>
</div>

<div class="section">
  <h2>احجز خدمتك الآن</h2>

  <input id="name" placeholder="الاسم">
  <input id="phone" placeholder="رقم الهاتف">
  
  <select id="service">
    <option>اختر الخدمة</option>
    <option>تنظيف منازل</option>
    <option>تنظيف مكيفات</option>
    <option>تنظيف خزانات</option>
  </select>

  <br>
  <button onclick="sendData()">إرسال</button>
</div>

<a href="https://wa.me/966565561900" target="_blank"
style="position:fixed;bottom:20px;left:20px;background:#25D366;padding:15px;border-radius:50%;">
📞
</a>

<script>
async function sendData() {
  const name = document.getElementById("name").value;
  const phone = document.getElementById("phone").value;
  const service = document.getElementById("service").value;

  if(!name || !phone){
    alert("املأ البيانات");
    return;
  }

  try {
    // إرسال البيانات لـ Make Webhook
    await fetch("https://hook.us2.make.com/ijrwvjy2k63b70cr5y4fltg7t26bsiud", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        name: name,
        phone: phone,
        service: service
      })
    });

    // فتح واتساب
    window.open("https://wa.me/966565561900", "_blank");

    alert("تم إرسال الطلب ✅");

  } catch (error) {
    alert("حصل خطأ حاول تاني");
  }
}
</script>

</body>
</html>
